{
  "suite_id": "bbob_noiseless",
  "name": "BBOB Noiseless Benchmark Suite",
  "description": "The 24 noiseless functions from the BBOB (Black-Box Optimization Benchmarking) test suite, as defined by Hansen et al. (2009). Unlike CEC suites, BBOB uses seeded random instance generation (x_opt, f_opt, rotations). Construction is handled programmatically by BBOBSuiteFactory; nested 'function' templates below show the correct nesting structure with null for instance-specific parameters.",
  "version": "2.0",
  "reference": "Hansen, N., Finck, S., Ros, R., & Auger, A. (2009). Real-parameter black-box optimization benchmarking 2009: Noiseless functions definitions. INRIA Technical Report RR-6829.",
  "instance_generation": "programmatic",
  "dimensions": {
    "supported": [
      2,
      3,
      5,
      10,
      20,
      40
    ],
    "default": 10
  },
  "search_space": {
    "default_bounds": {
      "min": -5,
      "max": 5
    }
  },
